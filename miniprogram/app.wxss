/* 全局样式 - 暖色美食风 */
page {
  background-color: #FFF8F0;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #2D2D2D;
  font-size: 28rpx;
  line-height: 1.6;
}

/* 主题色变量 */
.theme-primary {
  color: #FF6B35;
}

.theme-secondary {
  color: #FFA62B;
}

.theme-bg {
  background-color: #FFF8F0;
}

/* 通用容器 */
.container {
  padding: 24rpx;
}

/* 通用卡片 */
.card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.08);
}

/* 通用按钮 */
.btn-primary {
  background: linear-gradient(135deg, #FF6B35, #FFA62B);
  color: #FFFFFF;
  border: none;
  border-radius: 50rpx;
  padding: 20rpx 48rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-primary:active {
  opacity: 0.85;
  transform: scale(0.98);
}

/* 通用标签 */
.tag {
  display: inline-block;
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  margin: 6rpx;
}

.tag-selected {
  background: linear-gradient(135deg, #FF6B35, #FFA62B);
  color: #FFFFFF;
}

.tag-unselected {
  background: #FFF0E6;
  color: #FF6B35;
  border: 2rpx solid #FFD4BC;
}

/* 通用标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid #FF6B35;
}

/* 加载提示 */
.loading {
  text-align: center;
  padding: 60rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 60rpx;
}

.empty-state image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
}

.empty-state text {
  display: block;
  color: #999;
  font-size: 28rpx;
}
