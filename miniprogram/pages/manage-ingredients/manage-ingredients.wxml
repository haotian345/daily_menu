<view class="page-container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && ingredients.length === 0}}">
    <text class="empty-icon">🥬</text>
    <text class="empty-title">暂无自定义食材</text>
    <text class="empty-desc">点击下方按钮添加你常用的食材</text>
  </view>

  <!-- 食材列表 -->
  <view class="item-list" wx:if="{{!loading && ingredients.length > 0}}">
    <view class="list-header">
      <text class="list-title">我的食材（{{ingredients.length}}）</text>
    </view>
    <view class="item-card" wx:for="{{ingredients}}" wx:key="_id">
      <view class="item-main" bindtap="showEditDialog" data-item="{{item}}">
        <text class="item-icon">{{item.icon || '🍽'}}</text>
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-category">{{item.category}}</text>
        </view>
      </view>
      <view class="item-delete" bindtap="deleteIngredient" data-id="{{item._id}}" data-name="{{item.name}}">
        <text>删除</text>
      </view>
    </view>
  </view>

  <!-- 添加按钮 -->
  <view class="fab-btn" bindtap="showAddDialog">
    <text class="fab-icon">+</text>
  </view>

  <!-- 添加/编辑弹窗 -->
  <view class="modal-mask" wx:if="{{showAdd}}" bindtap="hideAddDialog"></view>
  <view class="modal-dialog" wx:if="{{showAdd}}">
    <view class="modal-title">{{editMode ? '编辑食材' : '添加食材'}}</view>
    <view class="form-group">
      <text class="form-label">食材名称</text>
      <input class="form-input" placeholder="请输入食材名称" value="{{form.name}}" bindinput="onNameInput" />
    </view>
    <view class="form-group">
      <text class="form-label">所属分类</text>
      <picker class="form-picker" range="{{categories}}" value="{{categories.indexOf(form.category)}}" bindchange="onCategoryChange}">
        <view class="picker-text">{{form.category}} ▾</view>
      </picker>
    </view>
    <view class="modal-actions">
      <view class="modal-btn modal-btn-cancel" bindtap="hideAddDialog">取消</view>
      <view class="modal-btn modal-btn-confirm" bindtap="saveIngredient">保存</view>
    </view>
  </view>
</view>
