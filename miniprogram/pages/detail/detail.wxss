/* 详情页样式 */
.page-container {
  min-height: 100vh;
  background: #FFF8F0;
}

/* 加载 & 空状态 */
.loading-state {
  text-align: center;
  padding: 200rpx 0;
  color: #999;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #FFD4BC;
  border-top: 4rpx solid #FF6B35;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin: 0 auto 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty-state {
  text-align: center;
  padding: 200rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.empty-title {
  display: block;
  font-size: 32rpx;
  color: #333;
}

/* 头部信息卡 */
.detail-header {
  position: relative;
  padding: 50rpx 30rpx 30rpx;
  margin-bottom: 20rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #FF6B35, #FF8C42, #FFA62B);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.dish-name {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.dish-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 24rpx;
}

.dish-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.meta-badge {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.2);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #FFFFFF;
  backdrop-filter: blur(10px);
}

.badge-icon {
  margin-right: 6rpx;
}

/* 操作按钮栏 */
.action-bar {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  margin: 0 24rpx 20rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.08);
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 20rpx;
  background: transparent;
  border: none;
  line-height: normal;
}

.action-btn::after {
  border: none;
}

.action-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
}

.action-text {
  font-size: 22rpx;
  color: #666;
}

.share-btn {
  margin: 0;
  padding: 8rpx 20rpx;
  background: transparent;
}

/* 通用卡片区块 */
.section-card {
  margin: 0 24rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.08);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #2D2D2D;
  padding-left: 16rpx;
  border-left: 6rpx solid #FF6B35;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
}

.section-header .section-title {
  margin-bottom: 0;
}

.section-action {
  font-size: 24rpx;
  color: #FF6B35;
}

/* 锅具标签 */
.cookware-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.cookware-tag {
  background: #FFF5ED;
  color: #FF6B35;
  padding: 10rpx 24rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  border: 2rpx solid #FFD4BC;
}

/* 食材清单 */
.ingredient-list {
  margin-top: 10rpx;
}

.ingredient-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.ingredient-row:last-child {
  border-bottom: none;
}

.ing-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.ing-amount {
  font-size: 26rpx;
  color: #FF6B35;
  font-weight: 500;
}

/* 烹饪步骤 */
.steps-list {
  margin-top: 10rpx;
}

.step-item {
  display: flex;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.step-item:last-child {
  margin-bottom: 0;
}

.step-number {
  flex-shrink: 0;
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #FF6B35, #FFA62B);
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  margin-top: 4rpx;
}

.step-content {
  flex: 1;
}

.step-desc {
  font-size: 28rpx;
  color: #333;
  line-height: 1.8;
  display: block;
}

.step-image {
  width: 100%;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

/* 小贴士 */
.tips-card {
  background: linear-gradient(135deg, #FFF8F0, #FFF5ED);
  border: 2rpx solid #FFD4BC;
}

.tips-icon {
  margin-right: 8rpx;
}

.tips-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
  display: block;
  padding-left: 22rpx;
}

/* 自定义菜谱操作按钮 */
.custom-actions {
  display: flex;
  gap: 16rpx;
  margin: 0 24rpx 20rpx;
}

.custom-action-btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.custom-action-btn .action-icon {
  font-size: 32rpx;
  margin-bottom: 0;
}

.custom-action-btn .action-text {
  font-size: 28rpx;
}

.edit-btn {
  background: #FFF5ED;
  color: #FF6B35;
  border: 2rpx solid #FFD4BC;
}

.delete-btn {
  background: #FFF1F0;
  color: #FF4D4F;
  border: 2rpx solid #FFCCC7;
}
