<view class="page-container">
  <!-- 加载中 -->
  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text>加载中...</text>
  </view>

  <!-- 未找到 -->
  <view class="empty-state" wx:if="{{notFound}}">
    <text class="empty-icon">😕</text>
    <text class="empty-title">菜谱不存在</text>
  </view>

  <!-- 菜谱详情 -->
  <block wx:if="{{!loading && !notFound && recipe}}">
    <!-- 头部信息卡 -->
    <view class="detail-header">
      <view class="header-bg"></view>
      <view class="header-content">
        <text class="dish-name">{{recipe.name}}</text>
        <text class="dish-desc">{{recipe.description}}</text>
        <view class="dish-meta">
          <view class="meta-badge">
            <text class="badge-icon">⏱</text>
            <text>{{recipe.cookTime}}</text>
          </view>
          <view class="meta-badge">
            <text class="badge-icon">📊</text>
            <text>{{recipe.difficulty}}</text>
          </view>
          <view class="meta-badge">
            <text class="badge-icon">🍽</text>
            <text>{{recipe.servings}}</text>
          </view>
          <view class="meta-badge">
            <text class="badge-icon">🏷</text>
            <text>{{recipe.category}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="action-bar">
      <view class="action-btn" bindtap="copyIngredients">
        <text class="action-icon">📋</text>
        <text class="action-text">复制清单</text>
      </view>
      <view class="action-btn" bindtap="openVideo">
        <text class="action-icon">🎬</text>
        <text class="action-text">视频教程</text>
      </view>
      <view class="action-btn" bindtap="toggleFavorite">
        <text class="action-icon">❤️</text>
        <text class="action-text">收藏</text>
      </view>
      <button class="action-btn share-btn" open-type="share">
        <text class="action-icon">🔗</text>
        <text class="action-text">分享</text>
      </button>
    </view>

    <!-- 自定义菜谱操作按钮 -->
    <view class="custom-actions" wx:if="{{isCustom}}">
      <view class="custom-action-btn edit-btn" bindtap="editRecipe">
        <text class="action-icon">✏️</text>
        <text class="action-text">编辑菜谱</text>
      </view>
      <view class="custom-action-btn delete-btn" bindtap="deleteRecipe">
        <text class="action-icon">🗑️</text>
        <text class="action-text">删除菜谱</text>
      </view>
    </view>

    <!-- 所需锅具 -->
    <view class="section-card">
      <view class="section-title">所需锅具</view>
      <view class="cookware-tags">
        <text class="cookware-tag" wx:for="{{recipe.cookware}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 食材清单 -->
    <view class="section-card">
      <view class="section-header">
        <text class="section-title">食材清单</text>
        <text class="section-action" bindtap="copyIngredients">一键复制</text>
      </view>
      <view class="ingredient-list">
        <view class="ingredient-row" wx:for="{{recipe.ingredients}}" wx:key="name">
          <text class="ing-name">{{item.name}}</text>
          <text class="ing-amount">{{item.amount}}</text>
        </view>
      </view>
    </view>

    <!-- 烹饪步骤 -->
    <view class="section-card">
      <view class="section-title">烹饪步骤</view>
      <view class="steps-list">
        <view class="step-item" wx:for="{{recipe.steps}}" wx:key="index">
          <view class="step-number">{{index + 1}}</view>
          <view class="step-content">
            <text class="step-desc">{{item.description}}</text>
            <image
              class="step-image"
              wx:if="{{item.image}}"
              src="{{item.image}}"
              mode="widthFix"
            />
          </view>
        </view>
      </view>
    </view>

    <!-- 烹饪小贴士 -->
    <view class="section-card tips-card" wx:if="{{recipe.tips}}">
      <view class="section-title">
        <text class="tips-icon">💡</text>
        烹饪小贴士
      </view>
      <text class="tips-content">{{recipe.tips}}</text>
    </view>

    <!-- 底部占位 -->
    <view style="height: 40rpx;"></view>
  </block>
</view>
