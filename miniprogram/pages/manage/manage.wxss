.page-container {
  min-height: 100vh;
  background: #FFF8F0;
  padding: 20rpx 24rpx;
}

.manage-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 40rpx;
}

.header-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #2D2D2D;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: #999;
}

.menu-list {
  margin-top: 20rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(255, 107, 53, 0.08);
}

.menu-icon {
  font-size: 48rpx;
  margin-right: 24rpx;
}

.menu-info {
  flex: 1;
}

.menu-name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #2D2D2D;
  margin-bottom: 4rpx;
}

.menu-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.menu-arrow {
  font-size: 40rpx;
  color: #CCC;
  margin-left: 12rpx;
}
