<view class="page-container">
  <!-- 顶部Banner -->
  <view class="banner">
    <view class="banner-content">
      <text class="banner-title">今天吃什么？</text>
      <text class="banner-subtitle">选食材、挑锅具，发现美味食谱</text>
    </view>
    <view class="banner-random" bindtap="randomRecommend">
      <text class="random-icon">🎲</text>
      <text class="random-text">随机推荐</text>
    </view>
  </view>

  <!-- 已选食材和锅具 -->
  <view class="selection-bar" wx:if="{{hasSelection}}">
    <view class="selection-header">
      <text class="selection-title">已选择</text>
      <text class="selection-clear" bindtap="clearAll">清空</text>
    </view>
    <view class="selection-tags">
      <view class="sel-tag" wx:for="{{selectedIngredients}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="sel-tag-close" bindtap="removeIngredient" data-name="{{item}}">✕</text>
      </view>
      <view class="sel-tag cookware-tag" wx:for="{{selectedCookware}}" wx:key="*this">
        <text>{{item}}</text>
        <text class="sel-tag-close" bindtap="removeCookware" data-name="{{item}}">✕</text>
      </view>
    </view>
  </view>

  <!-- 食材选择区 -->
  <view class="section">
    <view class="section-title">选择食材</view>
    <view class="ingredient-area">
      <!-- 左侧分类 -->
      <scroll-view class="category-nav" scroll-y>
        <view
          class="category-item {{activeCategory === index ? 'category-active' : ''}}"
          wx:for="{{ingredientCategories}}"
          wx:key="name"
          bindtap="switchCategory"
          data-index="{{index}}"
        >
          <text class="category-icon">{{item.icon}}</text>
          <text class="category-name">{{item.name}}</text>
        </view>
      </scroll-view>
      <!-- 右侧食材列表 -->
      <scroll-view class="ingredient-list" scroll-y>
        <view class="ingredient-grid">
          <view
            class="ingredient-chip {{selectedIngredients.indexOf(item) > -1 ? 'chip-active' : ''}}"
            wx:for="{{ingredientCategories[activeCategory].items}}"
            wx:key="*this"
            wx:for-item="item"
            bindtap="toggleIngredient"
            data-name="{{item}}"
          >
            <text>{{item}}</text>
          </view>
          <!-- 快速添加食材按钮 -->
          <view class="ingredient-chip chip-add" bindtap="showQuickAddIngredient">
            <text>+ 自定义</text>
          </view>
        </view>
      </scroll-view>
    </view>
  </view>

  <!-- 锅具选择区 -->
  <view class="section">
    <view class="section-title">选择锅具</view>
    <view class="cookware-grid">
      <view
        class="cookware-item {{selectedCookware.indexOf(item.name) > -1 ? 'cookware-active' : ''}}"
        wx:for="{{cookwareList}}"
        wx:key="name"
        bindtap="toggleCookware"
        data-name="{{item.name}}"
      >
        <text class="cookware-icon">{{item.icon}}</text>
        <text class="cookware-name">{{item.name}}</text>
        <view class="cookware-check" wx:if="{{selectedCookware.indexOf(item.name) > -1}}">✓</view>
      </view>
      <!-- 快速添加锅具按钮 -->
      <view class="cookware-item cookware-add" bindtap="showQuickAddCookware">
        <text class="cookware-icon">+</text>
        <text class="cookware-name">自定义</text>
      </view>
    </view>
  </view>

  <!-- 底部操作栏 -->
  <view class="bottom-bar">
    <view class="manage-entry" bindtap="goManage">
      <text class="manage-icon">⚙️</text>
      <text class="manage-text">管理</text>
    </view>
    <view class="search-btn {{hasSelection ? '' : 'search-btn-disabled'}}" bindtap="searchRecipes">
      <text class="search-btn-text">{{hasSelection ? '查看能做的菜' : '请选择食材或锅具'}}</text>
      <text class="search-btn-count" wx:if="{{hasSelection}}">
        {{selectedIngredients.length}}种食材 · {{selectedCookware.length}}种锅具
      </text>
    </view>
  </view>

  <!-- 底部占位 -->
  <view class="bottom-placeholder"></view>

  <!-- 快速添加食材弹窗 -->
  <view class="modal-mask" wx:if="{{showAddIngredient}}" bindtap="hideQuickAddIngredient"></view>
  <view class="modal-dialog" wx:if="{{showAddIngredient}}">
    <view class="modal-title">添加食材</view>
    <view class="form-group">
      <text class="form-label">食材名称</text>
      <input class="form-input" placeholder="请输入食材名称" value="{{quickIngredientName}}" bindinput="onQuickIngredientInput" />
    </view>
    <view class="form-group">
      <text class="form-label">所属分类</text>
      <picker range="{{ingredientCategories}}" range-key="name" value="{{quickCategoryIndex}}" bindchange="onQuickCategoryChange">
        <view class="picker-text">{{quickIngredientCategory}} ▾</view>
      </picker>
    </view>
    <view class="modal-actions">
      <view class="modal-btn modal-btn-cancel" bindtap="hideQuickAddIngredient">取消</view>
      <view class="modal-btn modal-btn-confirm" bindtap="quickAddIngredient">添加</view>
    </view>
  </view>

  <!-- 快速添加锅具弹窗 -->
  <view class="modal-mask" wx:if="{{showAddCookware}}" bindtap="hideQuickAddCookware"></view>
  <view class="modal-dialog" wx:if="{{showAddCookware}}">
    <view class="modal-title">添加锅具</view>
    <view class="form-group">
      <text class="form-label">锅具名称</text>
      <input class="form-input" placeholder="请输入锅具名称" value="{{quickCookwareName}}" bindinput="onQuickCookwareInput" />
    </view>
    <view class="modal-actions">
      <view class="modal-btn modal-btn-cancel" bindtap="hideQuickAddCookware">取消</view>
      <view class="modal-btn modal-btn-confirm" bindtap="quickAddCookware">添加</view>
    </view>
  </view>
</view>
